{
  "name": "astock-tracker",
  "version": "1.0.0",
  "description": "A股实时收益追踪器 - 前后端不分离 Web 应用",
  "main": "server.js",
  "scripts": {
    "start": "npm run build && node server.js",
    "build": "vite build",
    "dev": "concurrently \"nodemon server.js\" \"vite\"",
    "docker:build": "docker build -t astock-tracker .",
    "docker:run": "docker run -p 3000:3000 astock-tracker"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-slow-down": "^3.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.19.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.6.2",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2",
    "vite": "^5.4.21"
  }
}
