# =====================================================================
# 敏感变量（JWT_SECRET、MYSQL_PASSWORD）不在此文件中配置
# 请在服务器上通过环境变量设置后再执行 docker-compose up -d，例如：
#   export JWT_SECRET=$(openssl rand -hex 64)
#   export MYSQL_PASSWORD=your_strong_password
# =====================================================================

# ─── 数据库 ────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_DATABASE=astock

# ─── 服务 ──────────────────────────────────────────────────────
# 服务监听端口
PORT=3000
# 运行环境：development（禁用 cluster）/ production（多核自动 fork）
NODE_ENV=production
# 是否启用 HTTPS 部署（true 时启用完整 CSP + HSTS，HTTP 部署时保持注释）
# HTTPS_ENABLED=true
# SSE 推送间隔（毫秒，默认 10000 即 10 秒）
SSE_INTERVAL_MS=10000

# ─── JWT / Cookie ──────────────────────────────────────────────
# Token 有效期（支持 7d / 24h / 3600 等格式）
JWT_EXPIRES_IN=7d
# Cookie 有效期（毫秒，默认 604800000 即 7 天，建议与 JWT_EXPIRES_IN 保持一致）
COOKIE_MAX_AGE_MS=604800000

# ─── 安全 / 认证 ──────────────────────────────────────────────
# bcrypt 加密轮数（建议 10~14，越高越安全但越慢；默认 12）
BCRYPT_ROUNDS=12

# ─── 限流 ──────────────────────────────────────────────────────
# 全局 API 限流：15 分钟内每 IP 最多请求次数（默认 300）
RATE_LIMIT_API_MAX=300
# 登录限流：5 分钟内每 IP 最多尝试次数（默认 10）
RATE_LIMIT_LOGIN_MAX=10
# 注册限流：1 小时内每 IP 最多注册次数（默认 5）
RATE_LIMIT_REGISTER_MAX=5

# ─── 性能 / 容量 ───────────────────────────────────────────────
# MySQL 连接池大小（生产多核环境建议设为 CPU 核数 × 2，默认 10）
MYSQL_CONN_LIMIT=10
# 持仓 SSE 最大并发连接数（默认 100）
MAX_SSE_CLIENTS=100
# 请求体大小上限（支持 100kb / 1mb 等格式，默认 100kb）
REQUEST_BODY_LIMIT=100kb

# ─── 缓存 ──────────────────────────────────────────────────────
# 持仓行情内存缓存时长（毫秒，默认 60000 即 60 秒）
QUOTE_CACHE_TTL_MS=60000

# ─── AI 投资顾问 ────────────────────────────────────────────────
# 【免费模式】OpenAI 兼容接口（普通用户使用，无需部署 Ollama）
# 推荐使用智谱 AI（GLM-4-Flash 完全免费，注册即用）：
#   1. 注册：https://open.bigmodel.cn
#   2. 控制台 → API 密钥 → 新建密钥 → 复制 sk-xxx
# 其他可选平台：SiliconFlow（siliconflow.cn）、DeepSeek（platform.deepseek.com）
OPENAI_API_BASE=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=sk-替换为你的APIKey
# 智谱免费模型：GLM-4-Flash-250414（对话）或 GLM-Z1-Flash（推理，更强）
OPENAI_FREE_MODEL=GLM-4-Flash-250414

# 【VIP 模式】Ollama 本地高级模型（VIP 用户专属，需服务器内存 ≥ 4GB）
# 设置 VIP：UPDATE users SET is_vip = 1 WHERE username = '用户名';
OLLAMA_BASE_URL=http://localhost:11434
# 使用的模型名称（推荐 qwen2.5:3b，约 1.9GB；也可选 qwen2.5:7b 效果更佳但需 4GB+）
OLLAMA_MODEL=qwen2.5:3b